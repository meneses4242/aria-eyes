{
  "name": "@aria-eyes/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Framework-agnostic color claim verification for accessibility testing",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "author": "Tonči Žižić",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "color-namer": "^1.4.0"
  },
  "keywords": [
    "accessibility", "a11y", "wcag", "wcag-2.1", "wcag-1.4.1", "wcag-1.1.1", "wcag-1.4.3",
    "color", "contrast", "color-contrast", "contrast-ratio", "color-verification",
    "aria-label", "alt-text", "color-name", "color-match",
    "accessibility-testing", "automated-testing", "accessibility-checker",
    "screen-reader", "assistive-technology",
    "axe-core", "pa11y", "lighthouse",
    "use-of-color", "non-text-content"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TonciZ/aria-eyes",
    "directory": "packages/core"
  }
}
